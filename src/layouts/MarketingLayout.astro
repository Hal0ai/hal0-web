---
/**
 * MarketingLayout — shared chrome for non-docs pages (/, /install,
 * /hardware, /roadmap). Reuses the global stylesheet (which carries
 * both Starlight tokens and the hal0 design system) and provides a
 * thin top nav + footer.
 *
 * Props:
 *   title         – <title> + og:title
 *   description?  – meta description + og:description
 *   ogImage?      – social card path (defaults to /og-default.png)
 *   navTone?      – "solid" (default) | "transparent" — only the
 *                   landing page wants transparent-on-top, because
 *                   only it has a full-bleed hero. Transparent navs
 *                   automatically promote to solid past the fold
 *                   (see the inline scroll watcher in <body>).
 */
import '../styles/global.css';
import Wordmark from '../components/Wordmark.astro';

// Preload the two latin web fonts that drive above-the-fold rendering —
// without these, the FOUT swap from system fallback → real font pushes
// CLS to ~0.21 on long pages like /hardware.
import geistLatin from '@fontsource-variable/geist/files/geist-latin-wght-normal.woff2?url';
import jbm700 from '@fontsource/jetbrains-mono/files/jetbrains-mono-latin-700-normal.woff2?url';
import jbm400 from '@fontsource/jetbrains-mono/files/jetbrains-mono-latin-400-normal.woff2?url';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  navTone?: 'transparent' | 'solid';
}

const {
  title,
  description = 'Local AI for your home. Strix Halo native.',
  ogImage = '/og-default.png',
  navTone = 'solid',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://hal0.dev').toString();
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0a0a0a" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/brand/logo-halo-dark-favico.png" />
    <link rel="mask-icon" href="/favicon.svg" color="#feaf00" />

    <!-- Preload critical latin web fonts so above-the-fold content
         doesn't reflow when the swap finally arrives. -->
    <link rel="preload" href={geistLatin} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={jbm700} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={jbm400} as="font" type="font/woff2" crossorigin />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />
  </head>

  <body class="min-h-screen bg-hal0-bg text-hal0-fg antialiased">
    <header
      class="hal0-nav sticky top-0 z-40"
      data-tone={navTone}
      data-scrolled="false"
    >
      <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
        <a href="/" class="flex items-center gap-2">
          <Wordmark size="text-xl" />
          <span class="sr-only">— home</span>
        </a>
        <ul class="hidden items-center gap-7 font-mono text-sm text-hal0-fg-muted md:flex">
          <li><a class="transition hover:text-hal0-fg" href="/#install">install</a></li>
          <li><a class="transition hover:text-hal0-fg" href="/#hardware">hardware</a></li>
          <li><a class="transition hover:text-hal0-fg" href="/#roadmap">roadmap</a></li>
          <li><a class="transition hover:text-hal0-fg" href="/docs/">docs</a></li>
          <li>
            <a
              class="transition hover:text-hal0-fg"
              href="https://github.com/hal0ai/hal0"
              rel="noopener"
            >github</a>
          </li>
        </ul>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="border-t border-hal0-border bg-hal0-bg-sunken">
      <div class="mx-auto flex max-w-6xl flex-col gap-4 px-6 py-10 text-sm text-hal0-fg-muted md:flex-row md:items-center md:justify-between">
        <div class="flex items-center gap-3">
          <Wordmark size="text-base" />
          <span class="font-mono text-xs text-hal0-fg-dim">
            Apache-2.0 · v0.2.0-alpha.3
          </span>
        </div>
        <ul class="flex flex-wrap items-center gap-6 font-mono text-xs">
          <li><a class="hover:text-hal0-fg" href="/docs/">docs</a></li>
          <li><a class="hover:text-hal0-fg" href="/#install">install</a></li>
          <li><a class="hover:text-hal0-fg" href="/#hardware">hardware</a></li>
          <li><a class="hover:text-hal0-fg" href="/#roadmap">roadmap</a></li>
          <li>
            <a class="hover:text-hal0-fg" href="mailto:hello@hal0.dev">
              hello@hal0.dev
            </a>
          </li>
          <li>
            <a class="hover:text-hal0-fg" href="https://github.com/hal0ai/hal0" rel="noopener">
              github
            </a>
          </li>
        </ul>
      </div>
    </footer>

    <!-- Scroll-aware navbar:
         data-tone='solid'                    → frosted bg + amber accent
         data-tone='transparent'              → bare (used at top of landing)
         data-tone='transparent' + scrolled   → promotes to solid

         The script is intentionally tiny (no client framework) and uses
         a passive scroll listener, throttled via requestAnimationFrame
         so it stays cheap on long scrolls. -->
    <script is:inline>
      (() => {
        const nav = document.querySelector('header.hal0-nav[data-tone="transparent"]');
        if (!nav) return;
        const threshold = () => window.innerHeight * 0.8;
        let ticking = false;
        const sync = () => {
          ticking = false;
          nav.dataset.scrolled = window.scrollY > threshold() ? 'true' : 'false';
        };
        const onScroll = () => {
          if (ticking) return;
          ticking = true;
          requestAnimationFrame(sync);
        };
        sync();
        window.addEventListener('scroll', onScroll, { passive: true });
        window.addEventListener('resize', sync, { passive: true });
      })();
    </script>
  </body>
</html>

<style>
  /* Two visual states, three triggers.
   *   - tone='solid'                     → solid (always lit)
   *   - tone='transparent'               → bare (only valid at top of landing)
   *   - tone='transparent' + scrolled    → promoted to solid
   *
   * Solid = frosted #0a0a0a, plus the "vacuum-tube" accent:
   *   1) a 1px filament along the bottom edge (gradient → centred amber)
   *   2) a soft amber halo glow under the filament (faint, large radius)
   * Both kept subtle — the goal is "the rack is on", not Vegas. */

  .hal0-nav {
    --hal0-nav-bg: transparent;
    --hal0-nav-shadow: 0 0 0 0 transparent;
    --hal0-nav-filament: 0;

    background-color: var(--hal0-nav-bg);
    box-shadow: var(--hal0-nav-shadow);
    transition:
      background-color 200ms var(--hal0-ease, ease),
      backdrop-filter 200ms var(--hal0-ease, ease),
      box-shadow 200ms var(--hal0-ease, ease);
    position: sticky;
    top: 0;
  }

  .hal0-nav[data-tone='solid'],
  .hal0-nav[data-tone='transparent'][data-scrolled='true'] {
    --hal0-nav-bg: rgba(10, 10, 10, 0.85);
    --hal0-nav-shadow: 0 1px 24px -10px rgba(255, 176, 0, 0.28);
    --hal0-nav-filament: 1;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  /* The filament — a 1px gradient line on the bottom edge that
   * brightens to sodium amber at centre. Faded by --hal0-nav-filament
   * so it inherits the same transition as the bg. */
  .hal0-nav::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -1px;
    height: 1px;
    background: linear-gradient(
      to right,
      transparent 0%,
      color-mix(in srgb, var(--hal0-accent) 60%, transparent) 50%,
      transparent 100%
    );
    opacity: var(--hal0-nav-filament, 0);
    transition: opacity 200ms var(--hal0-ease, ease);
    pointer-events: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .hal0-nav,
    .hal0-nav::after {
      transition: none;
    }
  }
</style>
