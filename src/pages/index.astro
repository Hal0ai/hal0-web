interface RoadmapItem { t: string; d: string; }
type RoadmapTheme = { id: string; name: string; blurb: string; shipped: RoadmapItem[]; soon: RoadmapItem[]; later: RoadmapItem[]; };
function pickStage(theme: RoadmapTheme, id: string): RoadmapItem[] {
  if (id === 'shipped') return theme.shipped;
  if (id === 'soon') return theme.soon;
  return theme.later;
}
