---
/**
 * Landing page — / (hal0.dev).
 *
 * Content sourced from CONTENT_BRIEF.md. Every claim and number on this
 * page has a citation in that file. No invented numbers, no lorem.
 *
 * Built from the shared components in src/components/. Landing-only
 * helpers live in src/components/landing/.
 */
import MarketingLayout from '../layouts/MarketingLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import CodeBlock from '../components/CodeBlock.astro';
import FeatureGrid from '../components/FeatureGrid.astro';
import FeatureCard from '../components/FeatureCard.astro';
import HardwareMatrix from '../components/HardwareMatrix.astro';
import ComparisonTable from '../components/ComparisonTable.astro';
import RoadmapColumn from '../components/RoadmapColumn.astro';
import RoadmapCard from '../components/RoadmapCard.astro';
import CTA from '../components/CTA.astro';
import LoadoutCard from '../components/landing/LoadoutCard.astro';

const canonicalUrl = 'https://hal0.dev/';

const softwareApplicationLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'hal0',
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'Linux',
  description:
    'Open-source home AI inference platform for Strix Halo / Ryzen AI Max+ 395. OpenAI-compatible /v1/* API, systemd-managed slots, prewired OpenWebUI, self-hosted, no telemetry.',
  url: canonicalUrl,
  downloadUrl: 'https://hal0.dev/install',
  license: 'https://www.apache.org/licenses/LICENSE-2.0',
  softwareVersion: 'v1 pre-alpha',
  codeRepository: 'https://github.com/hal0ai/hal0',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
  author: {
    '@type': 'Organization',
    name: 'hal0ai',
    url: 'https://github.com/hal0ai',
  },
};

const comparisonColumns = [
  { key: 'hal0', label: 'hal0', highlight: true },
  { key: 'ollama', label: 'ollama' },
  { key: 'lmstudio', label: 'LM Studio' },
  { key: 'llamacpp', label: 'raw llama.cpp' },
  { key: 'cloud', label: 'Cloud API' },
];

const comparisonRows = [
  {
    feature: 'OpenAI /v1/* surface',
    hal0: 'chat, embed, rerank, STT, TTS',
    ollama: 'chat-only subset',
    lmstudio: 'chat-only',
    llamacpp: 'raw HTTP',
    cloud: 'full',
  },
  {
    feature: 'systemd-managed lifecycle',
    hal0: true,
    ollama: 'partial',
    lmstudio: 'desktop app',
    llamacpp: 'DIY',
    cloud: 'n/a',
  },
  {
    feature: 'Hardware probe + fit warnings',
    hal0: true,
    ollama: false,
    lmstudio: false,
    llamacpp: false,
    cloud: 'n/a',
  },
  {
    feature: 'Headless one-line install',
    hal0: true,
    ollama: true,
    lmstudio: 'GUI installer',
    llamacpp: 'manual',
    cloud: 'n/a',
  },
  {
    feature: 'Multi-model concurrent slots',
    hal0: true,
    ollama: 'partial',
    lmstudio: false,
    llamacpp: 'DIY',
    cloud: true,
  },
  {
    feature: 'Bundled chat UI',
    hal0: 'OpenWebUI prewired',
    ollama: false,
    lmstudio: 'built-in',
    llamacpp: false,
    cloud: 'varies',
  },
  {
    feature: 'Signed self-update + rollback',
    hal0: 'cosign',
    ollama: 'manual',
    lmstudio: 'desktop updater',
    llamacpp: 'manual',
    cloud: 'n/a',
  },
  {
    feature: 'Data stays on your box',
    hal0: true,
    ollama: true,
    lmstudio: true,
    llamacpp: true,
    cloud: false,
  },
];

const hardwareRows = [
  {
    name: 'AMD Ryzen AI Max+ 395',
    vendor: 'AMD · "Strix Halo"',
    vram: 'Unified 128 GB',
    status: 'first-class' as const,
    highlight: true,
    notes:
      'Reference deployment. iGPU + XDNA NPU + UMA-aware probe. Vulkan default; FLM for NPU.',
  },
  {
    name: 'AMD Ryzen AI Max 385 / 390',
    vendor: 'AMD · "Strix Halo"',
    vram: 'Unified 64 GB',
    status: 'first-class' as const,
    notes:
      'Same path as the 128 GB SKU; small + mid tiers fit comfortably, 70B Q4 with shorter context.',
  },
  {
    name: 'NVIDIA RTX 30/40/50',
    vendor: 'NVIDIA',
    vram: '10–32 GB',
    status: 'supported' as const,
    notes: 'CUDA-backed llama.cpp. Same slot lifecycle, dedicated VRAM instead of UMA.',
  },
  {
    name: 'AMD Radeon RX 7000 / discrete',
    vendor: 'AMD',
    vram: '16–24 GB',
    status: 'supported' as const,
    notes: 'Vulkan path today; ROCm toolbox image on the build list for opt-in.',
  },
  {
    name: 'CPU-only x86_64',
    vendor: 'Intel / AMD',
    vram: 'System RAM',
    status: 'experimental' as const,
    notes:
      'Vulkan-CPU fallback. Small models only — CI runs Qwen 0.5B here. Not the headline experience.',
  },
];

const description =
  'hal0 is an open-source home AI inference platform built for the 128 GB Strix Halo / Ryzen AI Max+ 395. OpenAI-compatible /v1/* API, systemd-managed slots, self-hosted, no telemetry.';
---

<MarketingLayout
  title="hal0 — Local AI for your home. Strix Halo native."
  description={description}
>
  <HeroSection
    eyebrow="v1 pre-alpha · Apache-2.0"
    title="Local AI for your home. Strix Halo native."
    subtitle="hal0 turns a Ryzen AI Max+ 395 with 128 GB of unified memory into a polished, OpenAI-compatible inference box. Slots, dispatcher, prewired chat — one Linux command installs the lot."
    ctaPrimary={{ href: '/install', label: 'Install hal0' }}
    ctaSecondary={{ href: '/docs/getting-started/', label: 'Read the docs' }}
  >
    <CodeBlock slot="visual" lang="sh" title="install on any modern Linux box">
{`curl -fsSL https://hal0.dev/install | bash`}
    </CodeBlock>
  </HeroSection>

  <!-- Why hal0 — the 4 things that separate it from "another llama-server wrapper". -->
  <section class="border-b border-hal0-border bg-hal0-bg-sunken">
    <div class="mx-auto max-w-6xl px-6 py-20">
      <p class="mb-3 font-mono text-xs uppercase tracking-wider text-hal0-accent">
        Why hal0
      </p>
      <h2 class="mb-12 max-w-3xl text-balance text-3xl font-semibold tracking-tight text-hal0-fg md:text-4xl">
        A polished home AI box, not another llama-server wrapper.
      </h2>
      <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-4">
        <article class="rounded-lg border border-hal0-accent/40 bg-hal0-bg-elevated p-6 shadow-[inset_3px_0_0_var(--hal0-accent)]">
          <h3 class="mb-2 font-mono text-base font-semibold text-hal0-fg">
            Strix Halo first-class
          </h3>
          <p class="text-sm leading-relaxed text-hal0-fg-muted">
            UMA-aware hardware probe, FLM provider for the XDNA NPU,
            unified-memory slot fit warnings. The 128 GB Ryzen AI Max+
            395 is the reference deployment — not an afterthought port.
          </p>
        </article>
        <article class="rounded-lg border border-hal0-border bg-hal0-bg-elevated p-6">
          <h3 class="mb-2 font-mono text-base font-semibold text-hal0-fg">
            OpenAI-compatible
          </h3>
          <p class="text-sm leading-relaxed text-hal0-fg-muted">
            <code class="font-mono text-hal0-fg">/v1/chat</code>,
            <code class="font-mono text-hal0-fg">embeddings</code>,
            <code class="font-mono text-hal0-fg">rerankings</code>,
            <code class="font-mono text-hal0-fg">audio/transcriptions</code>,
            <code class="font-mono text-hal0-fg">audio/speech</code>.
            Drop in any OpenAI SDK — point it at
            <code class="font-mono text-hal0-fg">:8080</code>.
          </p>
        </article>
        <article class="rounded-lg border border-hal0-border bg-hal0-bg-elevated p-6">
          <h3 class="mb-2 font-mono text-base font-semibold text-hal0-fg">
            Lifecycle, not just launch
          </h3>
          <p class="text-sm leading-relaxed text-hal0-fg-muted">
            Each slot is a typed state machine (offline → pulling →
            starting → warming → ready → serving ↔ idle), persisted to
            disk and streamed over SSE. systemd owns the units; the API
            never holds a model in its own memory.
          </p>
        </article>
        <article class="rounded-lg border border-hal0-border bg-hal0-bg-elevated p-6">
          <h3 class="mb-2 font-mono text-base font-semibold text-hal0-fg">
            Open + no phone-home
          </h3>
          <p class="text-sm leading-relaxed text-hal0-fg-muted">
            Apache-2.0. Telemetry is off by default; the only optional
            ping carries hardware class + version + slot count. Your
            weights, your data, your box.
          </p>
        </article>
      </div>
    </div>
  </section>

  <!-- Features grid — 8 tiles, grounded in PLAN.md (see CONTENT_BRIEF features list). -->
  <FeatureGrid
    eyebrow="What ships in v1"
    title="A complete home inference platform."
    columns={4}
  >
    <FeatureCard title="Slot state machine" icon="layers">
      Every workload has typed states (offline → pulling → warming →
      ready → serving ↔ idle → unloading) with atomic transitions,
      persisted to <code>state.json</code> and streamed over SSE.
    </FeatureCard>
    <FeatureCard title="OpenAI /v1/* surface" icon="plug">
      Chat, completions, embeddings, rerank, audio transcriptions,
      audio speech, models. Same shapes any OpenAI SDK already speaks.
    </FeatureCard>
    <FeatureCard title="Dispatcher + single-flight" icon="route">
      Registry-aware routing, cold-cache prefetch, request coalescing,
      decision logging. A thundering herd of identical prefetches
      becomes one HTTP call.
    </FeatureCard>
    <FeatureCard title="Hardware-aware probe" icon="cpu">
      Detects GPU / NPU / unified memory, writes
      <code>/etc/hal0/hardware.json</code>, surfaces VRAM/RAM fit
      warnings inline in the slot form before you try to load.
    </FeatureCard>
    <FeatureCard title="Prewired OpenWebUI" icon="message-circle">
      Chat UI on <code>:3001</code>, zero config — the installer points
      it at the local hal0 API. Dashboard is for operating the box,
      not chatting.
    </FeatureCard>
    <FeatureCard title="Dashboard (Vue 3)" icon="gauge">
      Nine views — Slots, Models, Hardware, Logs, Settings, Providers,
      First-run, plus error shell. Dark by default. SSE-backed live
      status and log tail.
    </FeatureCard>
    <FeatureCard title="Atomic self-update" icon="refresh-cw">
      <code>hal0 update --channel stable|nightly</code>. Cosign-verified
      tarballs swap a <code>current</code> symlink; <code>--rollback</code>
      reverts. Slot units survive API restarts.
    </FeatureCard>
    <FeatureCard title="One-line install" icon="terminal">
      Linux + systemd, idempotent, non-interactive. Pre-flight checks,
      systemd template units, working slot defaults dropped on disk —
      no manual yaml.
    </FeatureCard>
  </FeatureGrid>

  <!-- Hardware matrix — Strix Halo highlighted, everything else honest. -->
  <section class="border-b border-hal0-border bg-hal0-bg-sunken">
    <div class="mx-auto max-w-6xl px-6 py-20">
      <p class="mb-3 font-mono text-xs uppercase tracking-wider text-hal0-accent">
        Hardware
      </p>
      <h2 class="mb-4 max-w-3xl text-balance text-3xl font-semibold tracking-tight text-hal0-fg md:text-4xl">
        Built for Strix Halo. Honest about everything else.
      </h2>
      <p class="mb-10 max-w-3xl text-pretty text-hal0-fg-muted">
        Linux + systemd is the only hard requirement
        (<code class="font-mono">installer/install.sh:86</code>). The
        probe picks the right provider; you don't pin a backend by hand.
      </p>
      <HardwareMatrix
        rows={hardwareRows}
        caption="Provider matrix — picked automatically by the hardware probe"
      />
      <p class="mt-6 max-w-3xl text-sm text-hal0-fg-dim">
        macOS and Windows are not in scope for v1. NPU benchmarks land
        once the FLM toolbox image is published to
        <code class="font-mono">ghcr.io/hal0ai/</code>.
      </p>
    </div>
  </section>

  <!-- Recommended loadouts — three highlights from CONTENT_BRIEF (Strix Halo). -->
  <section class="border-b border-hal0-border bg-hal0-bg">
    <div class="mx-auto max-w-6xl px-6 py-20">
      <p class="mb-3 font-mono text-xs uppercase tracking-wider text-hal0-accent">
        Recommended loadouts
      </p>
      <h2 class="mb-4 max-w-3xl text-balance text-3xl font-semibold tracking-tight text-hal0-fg md:text-4xl">
        Three starting points. Mix, match, swap.
      </h2>
      <p class="mb-10 max-w-3xl text-pretty text-hal0-fg-muted">
        Curated picks for the 128 GB Strix Halo — refreshed to the
        latest open-weight releases as of May 2026. The slot system
        takes a different model per slot whenever you change your mind.
        See the
        <a class="text-hal0-accent underline-offset-2 hover:underline" href="/hardware">
          full hardware page
        </a>
        for discrete-GPU and CPU loadouts.
      </p>
      <div class="grid gap-4 md:grid-cols-3">
        <LoadoutCard title="Coding · mid" sizeGb="~19 GB" tone="accent">
          <ul class="space-y-1.5">
            <li>
              <span class="text-hal0-accent">primary</span> ·
              Qwen3-Coder-30B-A3B-Instruct-Q4_K_M
            </li>
            <li>
              <span class="text-hal0-accent">embed</span> ·
              nomic-embed-text-v2-moe-Q4_K_M
            </li>
          </ul>
          <p class="mt-3 font-sans text-sm leading-relaxed text-hal0-fg-muted">
            MoE with 3B active params — runs near 3B speeds, reasons like
            a 30B. Pairs with a 140 MB embed for repo-aware search.
          </p>
          <Fragment slot="note">
            Fallback: Qwen2.5-Coder-32B-Instruct-Q4_K_M (~20 GB).
          </Fragment>
        </LoadoutCard>

        <LoadoutCard title="Voice mode" sizeGb="~3 GB">
          <ul class="space-y-1.5">
            <li>
              <span class="text-hal0-accent">primary</span> ·
              Qwen3-4B-Instruct-2507-Q4_K_M
            </li>
            <li>
              <span class="text-hal0-accent">stt</span> · Moonshine base
            </li>
            <li>
              <span class="text-hal0-accent">tts</span> · Kokoro-82M v1.0
            </li>
          </ul>
          <p class="mt-3 font-sans text-sm leading-relaxed text-hal0-fg-muted">
            Low-latency reply, edge-built STT, 54-voice TTS. 128 GB
            leaves the entire rest of the budget free for a second
            chat model warm in another slot.
          </p>
          <Fragment slot="note">
            STT alt: whisper-large-v3-turbo (~1.6 GB). TTS alt: F5-TTS.
          </Fragment>
        </LoadoutCard>

        <LoadoutCard title="Maxed-out · long context" sizeGb="~50 GB">
          <ul class="space-y-1.5">
            <li>
              <span class="text-hal0-accent">primary</span> ·
              Llama-4-Scout-17B-16E-Instruct-Q4_K_M
            </li>
            <li>
              <span class="text-hal0-accent">embed</span> · bge-m3
              (8192-token context)
            </li>
          </ul>
          <p class="mt-3 font-sans text-sm leading-relaxed text-hal0-fg-muted">
            10M-token context, MoE with 17B active. The biggest realistic
            single-model loadout that still leaves room for STT/TTS
            slots warm on 128 GB unified.
          </p>
          <Fragment slot="note">
            Alt: Hermes-4-70B-Q8_0 (~75 GB) trades size for quant
            headroom.
          </Fragment>
        </LoadoutCard>
      </div>

      <p class="mt-8 text-sm text-hal0-fg-dim">
        Loadouts are starting points. Every real install ends up
        tweaked. Sizes are published GGUF file sizes (Hugging Face, May
        2026); no tok/s numbers on this page.
      </p>
    </div>
  </section>

  <!-- Quickstart — the install one-liner + a real /v1/chat call against :8080. -->
  <section class="border-b border-hal0-border bg-hal0-bg">
    <div class="mx-auto max-w-6xl px-6 py-20">
      <p class="mb-3 font-mono text-xs uppercase tracking-wider text-hal0-accent">
        Quickstart
      </p>
      <h2 class="mb-4 max-w-3xl text-balance text-3xl font-semibold tracking-tight text-hal0-fg md:text-4xl">
        From zero to a live <code class="font-mono">/v1/chat</code> in two commands.
      </h2>
      <p class="mb-10 max-w-3xl text-pretty text-hal0-fg-muted">
        The installer is idempotent and non-interactive. It probes the
        hardware, writes <code class="font-mono">/etc/hal0/hardware.json</code>,
        drops working slot defaults, and brings the API up on
        <code class="font-mono">:8080</code>.
      </p>

      <div class="grid gap-4 md:grid-cols-2">
        <div>
          <p class="mb-3 font-mono text-xs uppercase tracking-wider text-hal0-fg-muted">
            1 · install
          </p>
          <CodeBlock lang="sh" title="install.sh">
{`# install on any modern Linux box with systemd
curl -fsSL https://hal0.dev/install | bash

# optional overrides
# HAL0_PORT=9090 HAL0_PREFIX=/opt/hal0 curl … | bash`}
          </CodeBlock>
        </div>
        <div>
          <p class="mb-3 font-mono text-xs uppercase tracking-wider text-hal0-fg-muted">
            2 · chat
          </p>
          <CodeBlock lang="sh" title="/v1/chat/completions">
{`curl http://localhost:8080/v1/chat/completions \\
  -H "Content-Type: application/json" \\
  -d '{
    "model": "qwen2.5-0.5b-instruct-q4_k_m",
    "messages": [{"role":"user","content":"Hello!"}]
  }'`}
          </CodeBlock>
        </div>
      </div>

      <p class="mt-8 max-w-3xl text-sm text-hal0-fg-dim">
        Prefer a chat UI? OpenWebUI ships prewired on
        <code class="font-mono">:3001</code>, pointed at the local
        hal0 API out of the box.
      </p>
    </div>
  </section>

  <!-- "Why not just X?" — honest comparison vs. ollama, LM Studio, raw llama.cpp, cloud. -->
  <section class="border-b border-hal0-border bg-hal0-bg-sunken">
    <div class="mx-auto max-w-6xl px-6 py-20">
      <p class="mb-3 font-mono text-xs uppercase tracking-wider text-hal0-accent">
        Comparison
      </p>
      <h2 class="mb-4 max-w-3xl text-balance text-3xl font-semibold tracking-tight text-hal0-fg md:text-4xl">
        Why not just ollama, LM Studio, or raw llama.cpp?
      </h2>
      <p class="mb-10 max-w-3xl text-pretty text-hal0-fg-muted">
        hal0 isn't an inference engine — it's the orchestration,
        lifecycle, and multi-modal surface around llama.cpp, FLM,
        Moonshine, and Kokoro. Honest take, in one table.
      </p>

      <ComparisonTable columns={comparisonColumns} rows={comparisonRows} />

      <div class="mt-10 grid gap-6 text-sm leading-relaxed text-hal0-fg-muted md:grid-cols-2">
        <p>
          <span class="font-mono text-hal0-fg">vs. ollama</span> —
          systemd-managed slots survive
          <code class="font-mono">hal0-api</code> restarts; the OpenAI
          surface includes embeddings, rerank,
          <em>and</em> STT/TTS, not just chat. Hardware probe + slot
          fit warnings are first-class.
        </p>
        <p>
          <span class="font-mono text-hal0-fg">vs. LM Studio</span> —
          Linux-first, headless-first, one-line install, no GUI
          required. Prewired OpenWebUI handles chat; the dashboard is
          for operating the box.
        </p>
        <p>
          <span class="font-mono text-hal0-fg">vs. raw llama.cpp</span>
          — hal0 owns the lifecycle: health probes, atomic env writes,
          cold-boot grace, single-flight prefetch, structured errors,
          signed self-update with rollback.
        </p>
        <p>
          <span class="font-mono text-hal0-fg">vs. cloud APIs</span> —
          your hardware, your data, your models. External upstreams
          (OpenRouter, Anthropic, OpenAI, custom) can be configured as
          fallbacks behind the same <code class="font-mono">/v1/*</code>
          surface — mix local + remote per-model in one config.
        </p>
      </div>
    </div>
  </section>

  <!-- Roadmap teaser — three highest-signal v0.2 items + a link to /roadmap. -->
  <section class="border-b border-hal0-border bg-hal0-bg">
    <div class="mx-auto max-w-6xl px-6 py-20">
      <div class="mb-10 flex flex-wrap items-end justify-between gap-4">
        <div class="max-w-3xl">
          <p class="mb-3 font-mono text-xs uppercase tracking-wider text-hal0-accent">
            Roadmap
          </p>
          <h2 class="mb-3 text-balance text-3xl font-semibold tracking-tight text-hal0-fg md:text-4xl">
            v1 shipped. v0.2 is where it gets interesting.
          </h2>
          <p class="text-pretty text-hal0-fg-muted">
            Phase 1 landed on 2026-05-15 — 353 unit tests passing,
            integration tier on Vulkan-CPU + Qwen 0.5B. Here's what's
            next.
          </p>
        </div>
        <a
          href="/roadmap"
          class="inline-flex items-center gap-2 rounded-md border border-hal0-border bg-hal0-bg-elevated px-4 py-2 font-mono text-sm text-hal0-fg transition hover:border-hal0-border-strong"
        >
          Full roadmap →
        </a>
      </div>

      <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-4">
        <RoadmapColumn title="Now" eyebrow="v1" tone="primary">
          <RoadmapCard title="Slot lifecycle + dispatcher" status="shipped" eta="v1">
            State machine, single-flight, adaptive cold-boot, atomic
            TOML config, structured error envelopes.
          </RoadmapCard>
          <RoadmapCard title="Four providers wired" status="shipped" eta="v1">
            llama.cpp (Vulkan), FLM (XDNA NPU), Moonshine (STT),
            Kokoro (TTS).
          </RoadmapCard>
        </RoadmapColumn>

        <RoadmapColumn title="Next" eyebrow="v0.2">
          <RoadmapCard title="Memory subsystem" status="next">
            Conversation memory store wired into the dispatcher —
            opt-in per slot.
          </RoadmapCard>
          <RoadmapCard title="MCP support" status="next">
            Model Context Protocol surface so hal0 can host MCP servers
            alongside slots.
          </RoadmapCard>
        </RoadmapColumn>

        <RoadmapColumn title="Next" eyebrow="v0.2">
          <RoadmapCard title="Kyuzo · image generation" status="next">
            ComfyUI-backed provider as a fourth slot class.
          </RoadmapCard>
          <RoadmapCard title="Caddy + auth + hal0.local" status="next">
            Reverse proxy with optional auth and mDNS so the box is
            reachable as <code>hal0.local</code> on your LAN.
          </RoadmapCard>
        </RoadmapColumn>

        <RoadmapColumn title="Packaging" eyebrow="v0.2">
          <RoadmapCard title="AUR + Ubuntu PPA" status="next">
            Distro-native packages alongside the curl installer.
          </RoadmapCard>
          <RoadmapCard title="Benchmarks + Presets UI" status="next">
            In-dashboard benchmark runner and one-click loadout
            presets.
          </RoadmapCard>
        </RoadmapColumn>
      </div>
    </div>
  </section>

  <!-- Trust / social proof — license, telemetry-off, cosign, GitHub. -->
  <section class="border-b border-hal0-border bg-hal0-bg-sunken">
    <div class="mx-auto max-w-6xl px-6 py-16">
      <p class="mb-3 font-mono text-xs uppercase tracking-wider text-hal0-accent">
        Trust
      </p>
      <h2 class="mb-10 max-w-3xl text-balance text-3xl font-semibold tracking-tight text-hal0-fg md:text-4xl">
        Boring guarantees, in writing.
      </h2>
      <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-4">
        <div class="rounded-lg border border-hal0-border bg-hal0-bg-elevated p-5">
