---
/**
 * Landing page — / (hal0.dev).
 *
 * Content sourced from CONTENT_BRIEF.md. Every claim and number on this
 * page has a citation in that file. No invented numbers, no lorem.
 *
 * Built from the shared components in src/components/. Landing-only
 * helpers live in src/components/landing/.
 */
import MarketingLayout from '../layouts/MarketingLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import CodeBlock from '../components/CodeBlock.astro';
import FeatureGrid from '../components/FeatureGrid.astro';
import FeatureCard from '../components/FeatureCard.astro';
import HardwareMatrix from '../components/HardwareMatrix.astro';
import ComparisonTable from '../components/ComparisonTable.astro';
import RoadmapColumn from '../components/RoadmapColumn.astro';
import RoadmapCard from '../components/RoadmapCard.astro';
import CTA from '../components/CTA.astro';
import LoadoutCard from '../components/landing/LoadoutCard.astro';

const canonicalUrl = 'https://hal0.dev/';

const softwareApplicationLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'hal0',
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'Linux',
  description:
    'Open-source homelab AI inference platform for Strix Halo / Ryzen AI Max+ 395. OpenAI-compatible /v1/* API, systemd-managed slots, prewired OpenWebUI, runs in a privileged Proxmox LXC, no telemetry.',
  url: canonicalUrl,
  downloadUrl: 'https://hal0.dev/install.sh',
  license: 'https://www.apache.org/licenses/LICENSE-2.0',
  softwareVersion: 'v0.1.0-alpha',
  codeRepository: 'https://github.com/hal0ai/hal0',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
  author: {
    '@type': 'Organization',
    name: 'hal0ai',
    url: 'https://github.com/hal0ai',
  },
};

const comparisonColumns = [
  { key: 'hal0', label: 'hal0', highlight: true },
  { key: 'ollama', label: 'ollama' },
  { key: 'lmstudio', label: 'LM Studio' },
  { key: 'llamacpp', label: 'raw llama.cpp' },
  { key: 'cloud', label: 'Cloud API' },
];

const comparisonRows = [
  {
    feature: 'OpenAI /v1/* surface',
    hal0: 'chat, embed, rerank, STT, TTS',
    ollama: 'chat-only subset',
    lmstudio: 'chat-only',
    llamacpp: 'raw HTTP',
    cloud: 'full',
  },
  {
    feature: 'systemd-managed lifecycle',
    hal0: true,
    ollama: 'partial',
    lmstudio: 'desktop app',
    llamacpp: 'DIY',
    cloud: 'n/a',
  },
  {
    feature: 'Hardware probe + fit warnings',
    hal0: true,
    ollama: false,
    lmstudio: false,
    llamacpp: false,
    cloud: 'n/a',
  },
  {
    feature: 'Headless one-line install',
    hal0: true,
    ollama: true,
    lmstudio: 'GUI installer',
    llamacpp: 'manual',
    cloud: 'n/a',
  },
  {
    feature: 'Multi-model concurrent slots',
    hal0: true,
    ollama: 'partial',
    lmstudio: false,
    llamacpp: 'DIY',
    cloud: true,
  },
  {
    feature: 'Bundled chat UI',
    hal0: 'OpenWebUI prewired',
    ollama: false,
    lmstudio: 'built-in',
    llamacpp: false,
    cloud: 'varies',
  },
  {
    feature: 'Signed self-update + rollback',
    hal0: 'cosign',
    ollama: 'manual',
    lmstudio: 'desktop updater',
    llamacpp: 'manual',
    cloud: 'n/a',
  },
  {
    feature: 'Data stays on your box',
    hal0: true,
    ollama: true,
    lmstudio: true,
    llamacpp: true,
    cloud: false,
  },
];

const hardwareRows = [
  {
    name: 'AMD Ryzen AI Max+ 395',
    vendor: 'AMD · "Strix Halo"',
    vram: 'Unified 128 GB',
    status: 'first-class' as const,
    highlight: true,
    notes:
      'Reference deployment. iGPU + XDNA NPU + UMA-aware probe. Vulkan default; FLM for NPU.',
  },
  {
    name: 'AMD Ryzen AI Max 385 / 390',
    vendor: 'AMD · "Strix Halo"',
    vram: 'Unified 64 GB',
    status: 'first-class' as const,
    notes:
      'Same path as the 128 GB SKU; small + mid tiers fit comfortably, 70B Q4 with shorter context.',
  },
  {
    name: 'NVIDIA RTX 30/40/50',
    vendor: 'NVIDIA',
    vram: '10–32 GB',
    status: 'supported' as const,
    notes: 'CUDA-backed llama.cpp. Same slot lifecycle, dedicated VRAM instead of UMA.',
  },
  {
    name: 'AMD Radeon RX 7000 / discrete',
    vendor: 'AMD',
    vram: '16–24 GB',
    status: 'supported' as const,
    notes: 'Vulkan path today; ROCm toolbox image on the build list for opt-in.',
  },
  {
    name: 'CPU-only x86_64',
    vendor: 'Intel / AMD',
    vram: 'System RAM',
    status: 'experimental' as const,
    notes:
      'Vulkan-CPU fallback. Small models only. CI runs Qwen 0.5B here. Not the headline experience.',
  },
];

const description =
  'hal0 is an open-source homelab AI inference platform built for the 128 GB Strix Halo / Ryzen AI Max+ 395. OpenAI-compatible /v1/* API, systemd-managed slots, runs in a privileged Proxmox LXC, no telemetry.';
---

<MarketingLayout
  title="hal0 — Homelab AI inference platform for tinkerers and devs."
  description={description}
>
  <HeroSection
    eyebrow="v0.1.0-alpha · Apache-2.0"
    title="Homelab AI inference platform for tinkerers and devs."
    subtitle="hal0 is what runs on the Linux box you already have in the rack. OpenAI-compatible API, systemd-managed slots, prewired chat UI. Happy in a Proxmox LXC with GPU and NPU passthrough, behind your Traefik."
    ctaPrimary={{ href: '/install', label: 'Install hal0' }}
    ctaSecondary={{ href: '/docs/getting-started/', label: 'Read the docs' }}
  >
    <CodeBlock slot="visual" lang="sh" title="install on any modern Linux box">
{`curl -fsSL https://hal0.dev/install.sh | bash`}
    </CodeBlock>
  </HeroSection>

  <!-- Why hal0 — the 4 things that make it a real homelab citizen. -->
  <section class="border-b border-hal0-border bg-hal0-bg-sunken">
    <div class="mx-auto max-w-6xl px-6 py-20">
      <p class="mb-3 font-mono text-xs uppercase tracking-wider text-hal0-accent">
        Why hal0
      </p>
      <h2 class="mb-12 max-w-3xl text-balance text-3xl font-semibold tracking-tight text-hal0-fg md:text-4xl">
        Built like a real homelab service.
      </h2>
      <div class="grid auto-rows-fr gap-4 md:grid-cols-2 lg:grid-cols-4">
        <article class="rounded-lg border border-hal0-accent/40 bg-hal0-bg-elevated p-6 shadow-[inset_3px_0_0_var(--hal0-accent)]">
          <h3 class="mb-2 font-mono text-base font-semibold text-hal0-fg">
            Strix Halo native
          </h3>
          <p class="text-sm leading-relaxed text-hal0-fg-muted">
            UMA-aware probe, FLM provider for the XDNA NPU,
            unified-memory slot-fit warnings sized to the real pool
            rather than the BAR carve-out. The 128 GB Ryzen AI Max+
            395 is the reference deployment. Every perf number on this
            page was measured there.
          </p>
        </article>
        <article class="rounded-lg border border-hal0-border bg-hal0-bg-elevated p-6">
          <h3 class="mb-2 font-mono text-base font-semibold text-hal0-fg">
            Concurrent chat + embed + voice
          </h3>
          <p class="text-sm leading-relaxed text-hal0-fg-muted">
            Five built-in slot classes (chat, embed, STT, TTS, image),
            each a real systemd-managed process on its own port. Run
            them at once. Primary + embed concurrent on Strix Halo
            measures <strong class="text-hal0-fg">~258 tok/s</strong>
            with <strong class="text-hal0-fg">&lt;200 ms</strong> dispatch.
          </p>
        </article>
        <article class="rounded-lg border border-hal0-border bg-hal0-bg-elevated p-6">
          <h3 class="mb-2 font-mono text-base font-semibold text-hal0-fg">
            Image gen, day one
          </h3>
          <p class="text-sm leading-relaxed text-hal0-fg-muted">
            <code class="font-mono text-hal0-fg">POST /v1/images/generations</code>
            served by ComfyUI on ROCm, inside the same slot lifecycle
            as everything else. Curated SDXL Turbo, SD 1.5, and Flux
            Schnell ship pre-pinned by sha256. Image gen is a real slot,
            on the same lifecycle as chat.
          </p>
        </article>
        <article class="rounded-lg border border-hal0-border bg-hal0-bg-elevated p-6">
          <h3 class="mb-2 font-mono text-base font-semibold text-hal0-fg">
            Dispatcher with single-flight
          </h3>
          <p class="text-sm leading-relaxed text-hal0-fg-muted">
            Registry-aware routing across local slots
            <em>and</em> external upstreams (OpenRouter, Anthropic,
            OpenAI). Cold-cache prefetch with request coalescing folds
            a thundering herd of identical prefetches into one HTTP
            call. Every routing decision logged as structured breadcrumbs.
          </p>
        </article>
      </div>
    </div>
  </section>

  <!-- Homelab section — Proxmox memory bar screenshot + LXC story. -->
  <section class="border-b border-hal0-border bg-hal0-bg">
    <div class="mx-auto max-w-6xl px-6 py-20">
      <p class="mb-3 font-mono text-xs uppercase tracking-wider text-hal0-accent">
        Runs in your rack
      </p>
      <h2 class="mb-4 max-w-3xl text-balance text-3xl font-semibold tracking-tight text-hal0-fg md:text-4xl">
        A tenant on your Proxmox node that admits it.
      </h2>
      <p class="mb-10 max-w-3xl text-pretty text-hal0-fg-muted">
        hal0 is happy in a privileged LXC with iGPU and XDNA passthrough
        (the recipe is in the docs). Drop a read-only PVE API token in
        Settings and the dashboard's unified-memory bar shows the
        physical DIMM total, your other tenants, ZFS ARC, and the free
        pool. Token sits 0600 at <code class="font-mono">/etc/hal0/proxmox.json</code>
        and the API redacts it on read.
      </p>

      <figure class="mb-12 overflow-hidden rounded-lg border border-hal0-border bg-hal0-bg-elevated">
        <img
          src="/screenshots/memory-bar.png"
          srcset="/screenshots/memory-bar.png 1x, /screenshots/memory-bar@2x.png 2x"
          alt="hal0 unified-memory bar showing GTT inference, system RAM, a muted Proxmox host segment, and free unified memory."
          width="1172"
          height="114"
          loading="lazy"
          class="block w-full"
        />
        <figcaption class="border-t border-hal0-border px-5 py-3 font-mono text-xs text-hal0-fg-muted">
          Dashboard memory bar. The <span class="text-hal0-fg">Proxmox host</span>
          segment is the other-tenant + ZFS ARC + kernel pressure
          competing for the same physical RAM pool.
        </figcaption>
      </figure>

      <div class="grid auto-rows-fr gap-4 md:grid-cols-2 lg:grid-cols-4">
        <article class="rounded-lg border border-hal0-border bg-hal0-bg-elevated p-6">
          <h3 class="mb-2 font-mono text-base font-semibold text-hal0-fg">
            Lives in an LXC
          </h3>
          <p class="text-sm leading-relaxed text-hal0-fg-muted">
            Privileged LXC + apparmor unconfined + dev0–dev3 passthrough
            gets you a full iGPU and XDNA NPU without burning a whole
            VM's worth of RAM. Bare-metal works too.
          </p>
        </article>
        <article class="rounded-lg border border-hal0-border bg-hal0-bg-elevated p-6">
          <h3 class="mb-2 font-mono text-base font-semibold text-hal0-fg">
            Behind your Traefik
          </h3>
          <p class="text-sm leading-relaxed text-hal0-fg-muted">
            Single port (<code class="font-mono">:8080</code>) for the
            API, <code class="font-mono">:3001</code> for OpenWebUI. Add
            a vhost on your Traefik or Caddy and you're done. Or run
            <code class="font-mono">--auth=basic</code> for a bundled
            Caddy with HTTPS and basic auth.
          </p>
        </article>
        <article class="rounded-lg border border-hal0-border bg-hal0-bg-elevated p-6">
          <h3 class="mb-2 font-mono text-base font-semibold text-hal0-fg">
            NFS-friendly model store
          </h3>
          <p class="text-sm leading-relaxed text-hal0-fg-muted">
            <code class="font-mono">/var/lib/hal0/models</code> is just a
            directory. Mount it from your NAS, point a fresh install at
            it with <code class="font-mono">--models-dir=PATH</code>, and
            switch backends without re-pulling.
          </p>
        </article>
        <article class="rounded-lg border border-hal0-border bg-hal0-bg-elevated p-6">
          <h3 class="mb-2 font-mono text-base font-semibold text-hal0-fg">
            systemd all the way
          </h3>
          <p class="text-sm leading-relaxed text-hal0-fg-muted">
            Slots are <code class="font-mono">hal0-slot@&lt;name&gt;.service</code>
            instances on a template unit. <code class="font-mono">systemctl status hal0-*</code>
            tells you what's actually running. Not an Electron app, not
            a daemon you have to nurse.
          </p>
        </article>
      </div>
    </div>
  </section>

  <!-- Features grid — 9 tiles in a 3x3. Headline platform features that
       aren't already covered by the "Why hal0" differentiator cards above
       (Strix Halo / concurrent perf / image gen / dispatcher live there). -->
  <FeatureGrid
    eyebrow="What ships in v1"
    title="The whole local AI stack, one install."
    columns={3}
  >
    <FeatureCard title="Five-provider stack" icon="layers-3">
      llama.cpp (Vulkan / ROCm / CUDA) for chat, embed, and rerank.
      FLM for the XDNA NPU. Moonshine for STT. Kokoro for TTS. ComfyUI
      for image gen. All wrapped in the same slot lifecycle.
    </FeatureCard>
    <FeatureCard title="OpenAI /v1/* surface" icon="plug">
      Chat, completions, embeddings, rerank, audio transcriptions,
      audio speech, images, models. Same shapes any OpenAI SDK already
      speaks. Point your client at <code>localhost:8080</code> and go.
    </FeatureCard>
    <FeatureCard title="Slot state machine" icon="layers">
      Every workload has typed states (offline → pulling → warming →
      ready → serving ↔ idle → unloading) with atomic transitions,
      persisted to <code>state.json</code> and streamed over SSE.
    </FeatureCard>
    <FeatureCard title="Capability cards" icon="cloud-download">
      Dashboard groups slots into <strong>Embed</strong>,
      <strong>Voice</strong>, and <strong>Img</strong> cards plus an
      <strong>NPU</strong> backend rollup. Pick a model and the
      orchestrator validates the (backend, model) pair against the
      catalog and reconciles the underlying slot on every apply.
      State lives in <code>/etc/hal0/capabilities.toml</code>.
    </FeatureCard>
    <FeatureCard title="Prewired OpenWebUI" icon="message-circle">
      Chat UI on <code>:3001</code> with zero config. The installer
      points it at the local hal0 API. The dashboard is for operating
      the box, not chatting.
    </FeatureCard>
    <FeatureCard title="Dashboard (Vue 3)" icon="gauge">
      Nine views (Slots, Models, Hardware, Logs, Settings, Providers,
      First-run, plus error shell). Dark by default. SSE-backed live
      status and log tail.
    </FeatureCard>
    <FeatureCard
      title="Auth + HTTPS, one flag"
      icon="shield-check"
      href="/docs/operate/auth/"
    >
      Off by default for trusted-LAN installs. <code>--auth=basic</code>
      brings up Caddy with basic_auth at the edge, bearer tokens for
      the OpenAI API, and automatic HTTPS (internal CA for
      <code>.local</code>, Let's Encrypt for real domains). No certbot
      ritual.
    </FeatureCard>
    <FeatureCard title="Atomic self-update" icon="refresh-cw">
      <code>hal0 update --channel stable|nightly</code>. Cosign-verified
      tarballs swap a <code>current</code> symlink; <code>--rollback</code>
      reverts. Slot units survive API restarts.
    </FeatureCard>
    <FeatureCard title="One-line install" icon="terminal">
      Linux + systemd, idempotent, non-interactive. Pre-flight checks,
      systemd template units, working slot defaults dropped on disk.
      No manual yaml.
    </FeatureCard>
  </FeatureGrid>

  <!-- See it running — the dashboard screenshot with a homelab caption. -->
  <section class="border-b border-hal0-border bg-hal0-bg-sunken">
    <div class="mx-auto max-w-6xl px-6 py-20">
      <p class="mb-3 font-mono text-xs uppercase tracking-wider text-hal0-accent">
        See it running
      </p>
      <h2 class="mb-4 max-w-3xl text-balance text-3xl font-semibold tracking-tight text-hal0-fg md:text-4xl">
        One dashboard, every slot, live.
      </h2>
      <p class="mb-10 max-w-3xl text-pretty text-hal0-fg-muted">
        KPIs across the top, the unified-memory bar in the middle (with
        the Proxmox host segment when a PVE token is configured), the
        slot grid below with per-slot T/S, ACT, MEM, and uptime. SSE
        keeps the numbers honest; <code class="font-mono">systemctl is-active</code>
        is the floor, not the ceiling.
      </p>

      <figure class="overflow-hidden rounded-lg border border-hal0-border bg-hal0-bg-elevated">
        <img
          src="/screenshots/dashboard-overview.png"
          srcset="/screenshots/dashboard-overview.png 1x, /screenshots/dashboard-overview@2x.png 2x"
          alt="hal0 dashboard at root path showing API and slot KPIs, the unified-memory bar with a Proxmox host segment, and the slot grid below."
          width="1440"
          height="900"
          loading="lazy"
          class="block w-full"
        />
        <figcaption class="border-t border-hal0-border px-5 py-3 font-mono text-xs text-hal0-fg-muted">
          Dashboard at <code class="text-hal0-fg">/</code>. The memory
          bar accounts for the LXC's GTT pool, the host's other PVE
          tenants, and free unified memory.
        </figcaption>
      </figure>
    </div>
  </section>

  <!-- Hardware matrix — Strix Halo highlighted, everything else honest. -->
  <section class="border-b border-hal0-border bg-hal0-bg-sunken">
    <div class="mx-auto max-w-6xl px-6 py-20">
      <p class="mb-3 font-mono text-xs uppercase tracking-wider text-hal0-accent">
        Hardware
      </p>
      <h2 class="mb-4 max-w-3xl text-balance text-3xl font-semibold tracking-tight text-hal0-fg md:text-4xl">
        Strix Halo is the reference. The rest of the matrix is honest.
      </h2>
      <p class="mb-10 max-w-3xl text-pretty text-hal0-fg-muted">
        Linux + systemd is the only hard requirement
        (<code class="font-mono">installer/install.sh:86</code>). The
        probe picks the right provider; you don't pin a backend by hand.
      </p>
      <HardwareMatrix
        rows={hardwareRows}
        caption="Provider matrix — picked automatically by the hardware probe"
      />
      <p class="mt-6 max-w-3xl text-sm text-hal0-fg-dim">
        macOS and Windows are not in scope for v1. The FLM NPU provider
        is live with a self-contained
        <code class="font-mono">ghcr.io/hal0ai/hal0-toolbox-flm:v1</code>
        image; NPU benchmarks land once the manifest digest pin lands
        in <code class="font-mono">hal0/manifest.json</code>.
      </p>
    </div>
  </section>

  <!-- Recommended loadouts — three highlights from CONTENT_BRIEF (Strix Halo). -->
  <section class="border-b border-hal0-border bg-hal0-bg">
    <div class="mx-auto max-w-6xl px-6 py-20">
      <p class="mb-3 font-mono text-xs uppercase tracking-wider text-hal0-accent">
        Recommended loadouts
      </p>
      <h2 class="mb-4 max-w-3xl text-balance text-3xl font-semibold tracking-tight text-hal0-fg md:text-4xl">
        Three starting points. Mix, match, swap.
      </h2>
      <p class="mb-10 max-w-3xl text-pretty text-hal0-fg-muted">
        Curated picks for the 128 GB Strix Halo — refreshed to the
        latest open-weight releases as of May 2026. The slot system
        takes a different model per slot whenever you change your mind.
        See the
        <a class="text-hal0-accent underline underline-offset-2 decoration-hal0-accent/50 hover:decoration-hal0-accent" href="/hardware">
          full hardware page
        </a>
        for discrete-GPU and CPU loadouts.
      </p>
      <div class="grid gap-4 md:grid-cols-3">
        <LoadoutCard title="Coding · mid" sizeGb="~19 GB" tone="accent">
          <ul class="space-y-1.5">
            <li>
              <span class="text-hal0-accent">primary</span> ·
              Qwen3-Coder-30B-A3B-Instruct-Q4_K_M
            </li>
            <li>
              <span class="text-hal0-accent">embed</span> ·
              nomic-embed-text-v2-moe-Q4_K_M
            </li>
          </ul>
          <p class="mt-3 font-sans text-sm leading-relaxed text-hal0-fg-muted">
            MoE with 3B active params. Runs near 3B speeds, reasons like
            a 30B. Pairs with a 140 MB embed for repo-aware search.
          </p>
          <Fragment slot="note">
            Fallback: Qwen2.5-Coder-32B-Instruct-Q4_K_M (~20 GB).
          </Fragment>
        </LoadoutCard>

        <LoadoutCard title="Voice mode" sizeGb="~3 GB">
          <ul class="space-y-1.5">
            <li>
              <span class="text-hal0-accent">primary</span> ·
              Qwen3-4B-Instruct-2507-Q4_K_M
            </li>
            <li>
              <span class="text-hal0-accent">stt</span> · Moonshine base
            </li>
            <li>
              <span class="text-hal0-accent">tts</span> · Kokoro-82M v1.0
            </li>
          </ul>
          <p class="mt-3 font-sans text-sm leading-relaxed text-hal0-fg-muted">
            Low-latency reply, edge-built STT, 54-voice TTS. 128 GB
            leaves the entire rest of the budget free for a second
            chat model warm in another slot.
          </p>
          <Fragment slot="note">
            STT alt: whisper-large-v3-turbo (~1.6 GB). TTS alt: F5-TTS.
          </Fragment>
        </LoadoutCard>

        <LoadoutCard title="Maxed-out · long context" sizeGb="~50 GB">
          <ul class="space-y-1.5">
            <li>
              <span class="text-hal0-accent">primary</span> ·
              Llama-4-Scout-17B-16E-Instruct-Q4_K_M
            </li>
            <li>
              <span class="text-hal0-accent">embed</span> · bge-m3
              (8192-token context)
            </li>
          </ul>
          <p class="mt-3 font-sans text-sm leading-relaxed text-hal0-fg-muted">
            10M-token context, MoE with 17B active. The biggest realistic
            single-model loadout that still leaves room for STT/TTS
            slots warm on 128 GB unified.
          </p>
          <Fragment slot="note">
            Alt: Hermes-4-70B-Q8_0 (~75 GB) trades size for quant
            headroom.
          </Fragment>
        </LoadoutCard>
      </div>

      <p class="mt-8 text-sm text-hal0-fg-dim">
        Loadouts are starting points. Every real install ends up
        tweaked. Sizes are published GGUF file sizes (Hugging Face, May
        2026); no tok/s numbers on this page.
      </p>
    </div>
  </section>

  <!-- Quickstart — the install one-liner + a real /v1/chat call against :8080. -->
  <section class="border-b border-hal0-border bg-hal0-bg">
    <div class="mx-auto max-w-6xl px-6 py-20">
      <p class="mb-3 font-mono text-xs uppercase tracking-wider text-hal0-accent">
        Quickstart
      </p>
      <h2 class="mb-4 max-w-3xl text-balance text-3xl font-semibold tracking-tight text-hal0-fg md:text-4xl">
        From zero to a live <code class="font-mono">/v1/chat</code> in two commands.
      </h2>
      <p class="mb-10 max-w-3xl text-pretty text-hal0-fg-muted">
        The installer is idempotent and non-interactive. It probes the
        hardware, writes <code class="font-mono">/etc/hal0/hardware.json</code>,
        drops working slot defaults, and brings the API up on
        <code class="font-mono">:8080</code>.
      </p>

      <div class="grid gap-4 md:grid-cols-2">
        <div>
          <p class="mb-3 font-mono text-xs uppercase tracking-wider text-hal0-fg-muted">
            1 · install
          </p>
          <CodeBlock lang="sh" title="install.sh">
{`# install on any modern Linux box with systemd
curl -fsSL https://hal0.dev/install.sh | bash

# optional overrides
# HAL0_PORT=9090 HAL0_PREFIX=/opt/hal0 curl … | bash`}
          </CodeBlock>
        </div>
        <div>
          <p class="mb-3 font-mono text-xs uppercase tracking-wider text-hal0-fg-muted">
            2 · chat
          </p>
          <CodeBlock lang="sh" title="/v1/chat/completions">
{`curl http://localhost:8080/v1/chat/completions \\
  -H "Content-Type: application/json" \\
  -d '{
    "model": "qwen2.5-0.5b-instruct-q4_k_m",
    "messages": [{"role":"user","content":"Hello!"}]
  }'`}
          </CodeBlock>
        </div>
      </div>

      <p class="mt-8 max-w-3xl text-sm text-hal0-fg-dim">
        Prefer a chat UI? OpenWebUI ships prewired on
        <code class="font-mono">:3001</code>, pointed at the local
        hal0 API out of the box.
      </p>
    </div>
  </section>

  <!-- Comparison — honest take on ollama, LM Studio, raw llama.cpp, cloud. -->
  <section class="border-b border-hal0-border bg-hal0-bg-sunken">
    <div class="mx-auto max-w-6xl px-6 py-20">
      <p class="mb-3 font-mono text-xs uppercase tracking-wider text-hal0-accent">
        Comparison
      </p>
      <h2 class="mb-4 max-w-3xl text-balance text-3xl font-semibold tracking-tight text-hal0-fg md:text-4xl">
        Where hal0 sits next to ollama, LM Studio, and raw llama.cpp.
      </h2>
      <p class="mb-10 max-w-3xl text-pretty text-hal0-fg-muted">
        hal0 isn't an inference engine. It's the orchestration,
        lifecycle, and multi-modal surface around llama.cpp, FLM,
        Moonshine, and Kokoro. Honest take, in one table.
      </p>

      <ComparisonTable columns={comparisonColumns} rows={comparisonRows} />

      <div class="mt-10 grid gap-6 text-sm leading-relaxed text-hal0-fg-muted md:grid-cols-2">
        <p>
          <span class="font-mono text-hal0-fg">vs. ollama.</span>
          systemd-managed slots survive
          <code class="font-mono">hal0-api</code> restarts. The OpenAI
          surface includes embeddings, rerank,
          <em>and</em> STT/TTS, not only chat. Hardware probe and slot
          fit warnings are first-class.
        </p>
        <p>
          <span class="font-mono text-hal0-fg">vs. LM Studio.</span>
          Linux-first, headless-first, one-line install, no GUI
          required. Prewired OpenWebUI handles chat; the dashboard is
          for operating the box.
        </p>
        <p>
          <span class="font-mono text-hal0-fg">vs. raw llama.cpp.</span>
          hal0 owns the lifecycle: health probes, atomic env writes,
          cold-boot grace, single-flight prefetch, structured errors,
          signed self-update with rollback.
        </p>
        <p>
          <span class="font-mono text-hal0-fg">vs. cloud APIs.</span>
          Your hardware, your data, your models. External upstreams
          (OpenRouter, Anthropic, OpenAI, custom) can be configured as
          fallbacks behind the same <code class="font-mono">/v1/*</code>
          surface, so you can mix local and remote per-model in one config.
        </p>
      </div>
    </div>
  </section>

