---
/**
 * /roadmap — direction for hal0. No dates, no commitments — these are
 * the shapes the platform is growing into.
 *
 * Two surfaces:
 *   1. "Shipping now" hero — the 4 most recently landed features in
 *      the current release (v0.2.0-alpha.3), foregrounded so the page
 *      reads "what's live and what's next" instead of a long history.
 *   2. Themed maturity matrix — six themes, each with three lanes
 *      (shipped, soon, exploring). Length scales horizontally inside
 *      a theme instead of letting Shipped grow into a wall.
 *
 * If you add a new shipped/soon/exploring item below, also map its
 * theme in `themeOf()` — items that don't match fall into "Security
 * + UX" by design (it's the catch-all for cross-cutting concerns).
 */
import MarketingLayout from '../layouts/MarketingLayout.astro';

const shipped = [
  {
    title: 'Signed release pipeline live',
    why: 'releases.hal0.dev/stable.json serves the live manifest via a Cloudflare Pages middleware proxy. A v* tag on hal0 publishes the GH release; the manifest reflects it within ~60s, no hal0-web deploy needed. cosign 3.x keyless verify (--certificate + cert_url in the manifest) against the GH Actions OIDC identity.',
  },
  {
    title: 'OpenAI-compatible /v1/* API',
    why: 'Chat, completions, embeddings, rerank, transcriptions, speech, images. Every OpenAI SDK works unchanged against the local box.',
  },
  {
    title: 'Slot lifecycle state machine',
    why: 'Real atomic transitions (offline → pulling → starting → warming → ready → serving), persisted and SSE-streamed so the dashboard reflects reality, not snapshots.',
  },
  {
    title: 'Hardware-aware probe',
    why: 'Detects GPU, NPU, and unified memory; surfaces VRAM/RAM fit warnings inline before you load a model that won’t fit.',
  },
  {
    title: 'Bundled OpenWebUI',
    why: 'Prewired chat on :3001 pointed at the local API. Zero config; the installer wires it for you.',
  },
  {
    title: 'Cosign-signed self-update',
    why: 'Atomic version swap with rollback. Stable and nightly channels, GitHub OIDC-verified release tarballs.',
  },
  {
    title: 'Five-provider stack',
    why: 'llama.cpp (Vulkan / ROCm) for chat and embed, FLM for NPU multiplex, Moonshine for STT, Kokoro for TTS, ComfyUI for image generation. All first-class in v1.',
  },
  {
    title: 'Image generation',
    why: 'POST /v1/images/generations served by a ComfyUI provider on ROCm. Curated SDXL Turbo / SD 1.5 / Flux Schnell with license badges; the img slot runs inside the same lifecycle as chat, embed, and audio.',
  },
  {
    title: 'Caddy + auth + HTTPS + mDNS',
    why: 'install.sh --auth=basic brings up Caddy at the edge with basic_auth, Bearer tokens for the OpenAI API, automatic HTTPS (internal CA for .local, Let’s Encrypt for real domains), and a best-effort Avahi service file so hal0.local resolves on the LAN. Off by default; opt in when you’re ready to expose the box.',
  },
  {
    title: 'Installer overhaul',
    why: 'ASCII banner + step counter, extracted preflight.sh (disk + ports + python + systemd), hal0 doctor for re-running it post-install, hardware cards + auto-populated slots/primary.toml, contextual ERR-trap recovery hints, and a live-hello + QR + reachability finish.',
  },
  {
    title: 'Capability slots overlay',
    why: 'Embed, Voice, and Img capability cards plus an NPU backend rollup in the dashboard, backed by /etc/hal0/capabilities.toml and GET|POST /api/capabilities/*. The orchestrator picks one model per child, validates (backend, model) pairs against the catalog, and reconciles drift on every apply.',
  },
  {
    title: 'FLM NPU provider live',
    why: 'Self-contained ghcr.io/hal0ai/hal0-toolbox-flm:v1 image bundles FLM and is pinned by sha256 in manifest.json alongside the other five toolbox images. Chat and embed surfaced in the picker only when XDNA hardware and the local toolbox image are both present. Model namespace comes from flm list -j; STT slice deferred.',
  },
  {
    title: 'Proxmox host-pressure segment',
    why: 'Drop a read-only PVEAuditor API token into Settings → Proxmox integration and the dashboard memory bar shows the physical DIMM total plus a muted Proxmox host segment for other-tenant + ZFS ARC + kernel pressure. Token sits 0600 at /etc/hal0/proxmox.json and the API redacts it on read; bare-metal installs leave the panel off.',
  },
  {
    title: 'embed-rerank built-in slot',
    why: 'The capability orchestrator auto-creates an embed-rerank slot on first enable: bge-reranker-v2-m3-q4_k_m on port 8086 with --reranking, so /v1/rerankings stays separate from the chat surface on :8081.',
  },
  {
    title: 'First-run wizard rewrite',
    why: 'Eight linear steps from password through hardware, primary model, capabilities, HF token, license, install, done. HF-token step is conditional on a gated model selection; legacy 5-step picker and three IA prototypes deleted.',
  },
  {
    title: '--models-dir install flag',
    why: 'install.sh --models-dir=PATH (or HAL0_MODELS_DIR, or an interactive tty prompt) points a fresh install at an existing model store. Persisted as [models].pull_root and included in [models].roots so the on-disk tree scans on first boot.',
  },
  {
    title: 'Models scan preview overhaul',
    why: 'POST /api/models/scan/preview is inspection-only; kind-driven gating (llama / moonshine / kokoro / flm), shared skip rules, per-row select, dedup across HF blob-cache symlinks, GGUF magic-byte detection regardless of extension, GGUF general.name → suggested name, HF-cache repo-name fallback.',
  },
  {
    title: 'Per-slot live metrics',
    why: 'GET /api/slots/metrics reads docker cgroup memory + ActiveEnterTimestampMonotonic + scraped llama-server /metrics, with a fallback to the systemd unit’s MemoryCurrent for native-host slots.',
  },
  {
    title: 'Orchestrator drift reconcile',
    why: 'CapabilityOrchestrator.apply() now reconciles capabilities.toml ↔ slots/*.toml on every call rather than only on selection diff, so prior failed applies, manual edits, and install-time seeds can no longer leave the two disagreeing.',
  },
  // ── v0.2.0-alpha.3 (2026-05-22) — landed this cut ──
  {
    title: 'Install + version flow locked down',
    why: '__version__ now reads from importlib.metadata instead of a hard-coded string; pyproject.toml is the single source of truth and the version-drift class of bug is gone. installer/install.sh copies the source tree into PREFIX so editable installs work from a temp checkout under any HAL0_PREFIX.',
  },
  {
    title: 'MCP tool annotations',
    why: 'All 22 admin tools and 4 standalone memory tools ship with MCP hint annotations (readOnly, destructive, idempotent, openWorld) so SDK clients can render confirmation UIs and reason about side-effects. ADR-0004 §1 documents the Anthropic-vs-Cline annotation-spec divergence.',
  },
  {
    title: 'KV-cache % gauge populates',
    why: 'Vulkan toolbox rebuilt against llama.cpp b9279 and the scrape now falls back to /slots when the legacy llamacpp:kv_cache_usage_ratio Prometheus gauge is missing — synthesises kv_cache_usage = max(n_prompt_tokens) / n_ctx, clamped at 1.0. The previously-empty cache tile on every llama slot finally has a number.',
  },
  {
    title: 'Live TTFT dashboard',
    why: 'Per-slot time-to-first-token sampled in the request dispatcher, surfaced as a sparkline-pinned HUD readout on SlotCard and aggregated to a fleet-wide card on the Dashboard. 60-second window; the SlotCard stats row drops to KV / ACT / MEM / UP because T/S and TTFT now live on the sparkline itself.',
  },
];

const soon = [
  {
    title: 'STT/TTS curated picks',
    why: 'v0.1.1 seeded the embed and rerank capability dropdowns with real GGUF picks (nomic, bge-base, embed-gemma, bge-reranker). STT (moonshine) and TTS (kokoro) need a pull-layer extension because their weights aren’t GGUF/safetensors — multi-file ONNX bundles + PyTorch pickles. Next 0.1.x slice teaches the pull route those shapes so the wizard can offer voice picks out of the box.',
  },
  {
    title: 'Agent management & integration',
    why: 'First-class agents stored on hal0 with conversation orchestration and deterministic tool-use loops. A place for agents to live on your box, not only to chat with.',
  },
  {
    title: 'Unified memory system',
    why: 'Persistent, federated memory across local slots and (optionally) external models. Mem0-style API with sources, search, and scoping.',
  },
  {
    title: 'MCP support, host and server',
    why: 'hal0 speaks Model Context Protocol both directions. Compose tools across local slots and external MCP services; discover them from the dashboard.',
  },
  {
    title: 'Extensions framework',
    why: 'Third-party apps packaged as hal0 extensions: systemd unit + dashboard tile + healthcheck. Bring-your-own-app, lifecycle-managed.',
  },
  {
    title: 'Benchmarks & presets UI',
    why: 'In-dashboard tok/s + latency runs, plus curated loadout presets you can flash onto a fresh install.',
  },
  {
    title: 'AUR PKGBUILD & Ubuntu PPA',
    why: 'Native distro packages on top of the install script: pacman and apt as first-class install paths.',
  },
];

const exploring = [
  {
    title: 'Multi-host federation',
    why: 'A slot mesh across LAN boxes: primary on the Strix Halo, embed on the workstation, all behind one /v1/* surface.',
  },
  {
    title: 'Fine-tune & LoRA hot-swap',
    why: 'Attach and rotate LoRAs against a warm base model without unloading the underlying weights.',
  },
  {
    title: 'Per-model rate limits & budgets',
    why: 'Cost-style accounting for local inference, so a chatty agent can be capped without taking the whole box down.',
  },
  {
    title: 'Voice mode end-to-end',
    why: 'Moonshine + agent loop + Kokoro stitched into a hands-free streaming conversation, gated through the slot lifecycle.',
  },
  {
    title: 'ChatOps adapters',
    why: 'Slack and Matrix bridges as extensions, so you can talk to hal0 from the rooms you already live in.',
  },
];

// ── Hero: 4 most recently landed features in the current release ──
// `shipped` is appended chronologically. The latest 4 entries are the
// headline features in the current alpha; surfacing them up top keeps
// the page anchored on "what's new" instead of "look how much we've done".
const heroFeatures = shipped.slice(-4).reverse();
const currentVersion = 'v0.2.0-alpha.3';

// ── Themed maturity matrix: six themes, three lanes per row ──
// `themeOf()` classifies an item from its title. Order here decides
// which theme an item lands in if it could match more than one — first
// match wins. The "Security + UX" theme is intentionally last so it
// acts as a catch-all for cross-cutting concerns (Caddy/auth, wizard,
// OpenWebUI, voice mode, STT/TTS) without forcing them into Inference.
const themeOf = (title: string): string => {
  if (/inference|provider|llama|FLM|moonshine|kokoro|comfyui|image generation|API|\/v1|fine.tune|lora|rate limit/i.test(title)) return 'inference';
  if (/slot|capability|orchestrator|metrics|embed.rerank|benchmark/i.test(title)) return 'slot';
  if (/install|release|cosign|update|models.scan|models.dir|AUR|PPA|extension/i.test(title)) return 'install';
  if (/hardware|probe|proxmox|host.pressure|federation|multi.host/i.test(title)) return 'hardware';
  if (/agent|memory|MCP|chatops/i.test(title)) return 'agents';
  return 'ux';
};
const themes = [
  { key: 'inference', label: 'Inference + providers',         accent: 'border-emerald-700/40' },
  { key: 'slot',      label: 'Slot lifecycle',                accent: 'border-cyan-700/40' },
  { key: 'install',   label: 'Install + distribution',        accent: 'border-purple-700/40' },
  { key: 'hardware',  label: 'Hardware + observability',      accent: 'border-rose-700/40' },
  { key: 'agents',    label: 'Agents + memory + MCP',         accent: 'border-hal0-accent/60' },
  { key: 'ux',        label: 'Security + UX',                 accent: 'border-amber-700/40' },
];
const grouped = themes.map((t) => ({
  ...t,
  shipped:   shipped.filter((i) => themeOf(i.title) === t.key),
  soon:      soon.filter((i) => themeOf(i.title) === t.key),
  exploring: exploring.filter((i) => themeOf(i.title) === t.key),
}));
---

<MarketingLayout
  title="hal0 roadmap — homelab AI platform, agents, memory, MCP"
  description="hal0 is an open-source, self-hosted LLM platform for the homelab: OpenAI-compatible API, slot lifecycle, local agent framework, MCP host. Roadmap for v1, v0.2, and beyond."
  navTone="solid"
>
  <section class="border-b border-hal0-border bg-hal0-bg">
    <div class="mx-auto max-w-6xl px-6 py-20 md:py-24">
      <span class="mb-6 inline-flex w-fit items-center gap-2 rounded-full border border-hal0-border bg-hal0-bg-elevated px-3 py-1 font-mono text-xs uppercase tracking-wider text-hal0-fg-muted">
        <span class="size-1.5 rounded-full bg-hal0-accent shadow-[0_0_8px_var(--hal0-accent)]"></span>
        roadmap
      </span>

      <h1 class="text-balance text-4xl font-semibold leading-tight tracking-tight text-hal0-fg md:text-5xl">
        One service for the whole local AI stack.
      </h1>

      <p class="mt-6 max-w-3xl text-pretty text-lg leading-relaxed text-hal0-fg-muted">
        v0.2.0-alpha.3 ships live dashboard metrics (per-slot TTFT
        and KV-cache %), a locked install + version flow, MCP tool
        annotations on every admin + memory tool, and the toolbox
        rebuild that finally lights up the cache gauge. The
        first-run wizard completes end-to-end on WSL 2, Proxmox VMs,
        and bare-metal Linux — not just Strix Halo. v0.2 takes the
        same lifecycle discipline and extends it into the rest of
        the local AI stack: agents, persistent memory, MCP, tools,
        image, voice, third-party extensions. The goal is one place
        on your hardware that runs the whole stack, instead of
        seven daemons glued together.
      </p>

      <p class="mt-4 max-w-3xl text-pretty text-sm leading-relaxed text-hal0-fg-dim">
        No dates below. Items are direction. Each themed row reads
        left-to-right: shipped, in flight, exploring — the closer to
        the left, the closer it is to running on your box.
      </p>
    </div>
  </section>

  {/* ── Shipping now hero — 4 latest landed features ── */}
  <section class="border-b border-hal0-border bg-hal0-bg">
    <div class="mx-auto max-w-6xl px-6 py-12 md:py-16">
      <div class="rounded-xl border border-hal0-accent/40 bg-gradient-to-br from-hal0-bg-elevated to-hal0-bg p-8 shadow-[inset_4px_0_0_var(--hal0-accent)] md:p-10">
        <div class="mb-3 flex items-baseline gap-3">
          <span class="font-mono text-xs uppercase tracking-wider text-hal0-accent">
            shipping now
          </span>
          <span class="font-mono text-sm text-hal0-fg-dim">{currentVersion}</span>
        </div>
        <h2 class="mb-6 text-balance text-2xl font-semibold tracking-tight text-hal0-fg md:text-3xl">
          Live dashboard metrics, locked install + version flow, MCP tool annotations.
        </h2>
        <div class="grid gap-4 md:grid-cols-2">
          {heroFeatures.map((item) => (
            <div class="rounded-md border border-hal0-border bg-hal0-bg-elevated/60 p-4">
              <h3 class="mb-2 font-mono text-sm font-medium text-hal0-fg">
                {item.title}
              </h3>
              <p class="text-sm leading-relaxed text-hal0-fg-muted">{item.why}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  {/* ── Themed maturity matrix — six themes × three lanes ── */}
  <section class="border-b border-hal0-border bg-hal0-bg">
    <div class="mx-auto max-w-7xl px-6 py-12 md:py-16">
      {/* Lane headers — centered over their columns (desktop only) */}
      <div class="mb-6 hidden grid-cols-[16rem_1fr_1fr_1fr] items-center gap-6 border-b border-hal0-border pb-3 md:grid">
        <span class="font-mono text-xs uppercase tracking-wider text-hal0-fg-dim">
          theme
        </span>
        <span class="text-center font-mono text-xs uppercase tracking-wider text-emerald-400">
          shipped
        </span>
        <span class="text-center font-mono text-xs uppercase tracking-wider text-hal0-accent">
          soon
        </span>
        <span class="text-center font-mono text-xs uppercase tracking-wider text-hal0-fg-dim">
          exploring
        </span>
      </div>

      <div class="space-y-6">
        {grouped.map((theme) => (
          <div class={`grid grid-cols-1 gap-4 rounded-lg border bg-hal0-bg-elevated/40 p-5 md:grid-cols-[16rem_1fr_1fr_1fr] ${theme.accent}`}>
            {/* Theme label column */}
            <div class="flex flex-col gap-2 border-b border-hal0-border pb-3 md:border-0 md:pb-0">
              <h3 class="font-mono text-base font-semibold text-hal0-fg">
                {theme.label}
              </h3>
              <div class="flex gap-3 font-mono text-[10px] uppercase tracking-wider text-hal0-fg-dim">
                <span><span class="text-emerald-400">{theme.shipped.length}</span> shipped</span>
                <span><span class="text-hal0-accent">{theme.soon.length}</span> soon</span>
                <span><span class="text-hal0-fg">{theme.exploring.length}</span> later</span>
              </div>
            </div>

            {/* Three lanes */}
            {(['shipped', 'soon', 'exploring'] as const).map((lane) => {
              const items = theme[lane];
              const laneStyles = {
                shipped:   { bullet: 'bg-emerald-500', text: 'text-emerald-300' },
                soon:      { bullet: 'bg-hal0-accent', text: 'text-hal0-accent' },
                exploring: { bullet: 'bg-hal0-fg-dim', text: 'text-hal0-fg-dim' },
              }[lane];
              return (
                <div class="flex flex-col gap-3">
                  {/* Mobile-only lane label (centered on mobile too) */}
                  <span class={`md:hidden text-center font-mono text-[10px] uppercase tracking-wider ${laneStyles.text}`}>
                    {lane}
                  </span>
                  {items.length === 0 ? (
                    <span class="font-mono text-xs italic text-hal0-fg-dim">—</span>
                  ) : (
                    items.map((item) => (
                      <div class="group">
                        <div class="flex items-baseline gap-2">
                          <span class={`mt-1.5 size-1.5 shrink-0 rounded-full ${laneStyles.bullet}`}></span>
                          <h4 class="font-mono text-sm leading-snug text-hal0-fg">
                            {item.title}
                          </h4>
                        </div>
                        <p class="ml-3.5 mt-1 text-xs leading-relaxed text-hal0-fg-muted">
                          {item.why}
                        </p>
                      </div>
                    ))
                  )}
                </div>
              );
            })}
          </div>
        ))}
      </div>

      <p class="mt-10 max-w-3xl text-sm leading-relaxed text-hal0-fg-dim">
        Exploring items are bets we believe in, not promises. Scope and
        order will shift as v0.2 lands and we learn what people actually
        do with a local platform.
      </p>
    </div>
  </section>

  <section class="bg-hal0-bg">
    <div class="mx-auto max-w-6xl px-6 py-16 md:py-20">
      <div class="rounded-lg border border-hal0-border bg-hal0-bg-elevated p-8 md:p-10">
        <p class="font-mono text-xs uppercase tracking-wider text-hal0-accent">
          shape it
        </p>
        <h2 class="mt-3 text-balance text-2xl font-semibold tracking-tight text-hal0-fg md:text-3xl">
          The roadmap is a conversation.
        </h2>
        <p class="mt-4 max-w-2xl text-pretty text-base leading-relaxed text-hal0-fg-muted">
          File issues, open discussions, send patches. hal0 is
          Apache-2.0; the platform is yours to extend, fork, or steer.
          The agents / memory / MCP track in particular benefits from
          real-world use cases more than from our guesses.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href="https://github.com/hal0ai/hal0/issues"
            rel="noopener"
            class="inline-flex items-center gap-2 rounded-md bg-hal0-accent px-5 py-3 font-mono text-sm font-medium text-black transition hover:bg-hal0-accent-hover focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-hal0-accent focus-visible:ring-offset-2 focus-visible:ring-offset-hal0-bg"
          >
            Open an issue
          </a>
          <a
            href="https://github.com/hal0ai/hal0"
            rel="noopener"
            class="inline-flex items-center gap-2 rounded-md border border-hal0-border bg-transparent px-5 py-3 font-mono text-sm font-medium text-hal0-fg transition hover:border-hal0-border-strong hover:bg-hal0-bg-elevated"
          >
            Browse the repo
          </a>
        </div>
      </div>
    </div>
  </section>
</MarketingLayout>
