---
/**
 * FeatureCard — single tile in a FeatureGrid.
 *
 * Props:
 *   icon  – lucide icon name (kebab-case, e.g. "layers", "refresh-cw").
 *           Renders via astro-icon against the @iconify-json/lucide
 *           pack. Any lucide-static name works.
 *   title – heading
 *   href  – optional link wrapper
 */
import { Icon } from 'astro-icon/components';

interface Props {
  icon?: string;
  title: string;
  href?: string;
}
const { icon, title, href } = Astro.props;
const Wrapper = href ? 'a' : 'div';
---

<Wrapper
  href={href}
  class:list={[
    'group block rounded-lg border border-hal0-border bg-hal0-bg-elevated p-6 transition',
    href && 'hover:border-hal0-accent hover:bg-hal0-bg-elevated/80 focus-visible:border-hal0-accent',
  ]}
>
  {icon && (
    <span
      aria-hidden="true"
      class="mb-4 inline-flex size-9 items-center justify-center rounded border border-hal0-border bg-hal0-bg text-hal0-accent"
    >
      <Icon name={`lucide:${icon}`} class="size-5" />
    </span>
  )}
  <h3 class="mb-2 font-mono text-base font-semibold tracking-tight text-hal0-fg">
    {title}
  </h3>
  <div class="text-sm leading-relaxed text-hal0-fg-muted">
    <slot />
  </div>
</Wrapper>
