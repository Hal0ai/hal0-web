---
/**
 * HardwareMatrix — comparison table of supported hardware. The
 * "Strix Halo" row is the crown jewel and gets the accent treatment.
 *
 * Props:
 *   rows – Array<{ name, vendor, vram, status, highlight?, notes? }>
 *
 * Status pill semantics:
 *   "first-class"  → green/accent, full support
 *   "supported"    → fg, working
 *   "experimental" → muted, opt-in
 *   "planned"      → dim, not yet
 */
type Status = 'first-class' | 'supported' | 'experimental' | 'planned';
interface Row {
  name: string;
  vendor: string;
  vram: string;
  status: Status;
  highlight?: boolean;
  notes?: string;
}
interface Props {
  rows: Row[];
  caption?: string;
}
const { rows, caption } = Astro.props;

const pillClass: Record<Status, string> = {
  'first-class':  'bg-hal0-accent text-black',
  'supported':    'bg-hal0-bg text-hal0-fg border border-hal0-border',
  'experimental': 'bg-hal0-bg text-hal0-fg-muted border border-hal0-border',
  'planned':      'bg-transparent text-hal0-fg-dim border border-hal0-border',
};
---

<div class="overflow-x-auto rounded-lg border border-hal0-border bg-hal0-bg-elevated">
  {caption && (
    <p class="border-b border-hal0-border px-5 py-3 font-mono text-xs uppercase tracking-wider text-hal0-fg-muted">
      {caption}
    </p>
  )}
  <table class="tabular w-full text-left text-sm">
    <thead class="bg-hal0-bg-sunken text-xs uppercase tracking-wider text-hal0-fg-muted">
      <tr>
        <th class="px-5 py-3 font-medium">Hardware</th>
        <th class="px-5 py-3 font-medium">Vendor</th>
        <th class="px-5 py-3 font-medium">Unified / VRAM</th>
        <th class="px-5 py-3 font-medium">Support</th>
        <th class="px-5 py-3 font-medium">Notes</th>
      </tr>
    </thead>
    <tbody>
      {rows.map((row) => (
        <tr
          class:list={[
            'border-t border-hal0-border',
            row.highlight && 'bg-[var(--hal0-accent-glow)]',
          ]}
        >
          <td class="px-5 py-4 font-mono font-medium text-hal0-fg">{row.name}</td>
          <td class="px-5 py-4 text-hal0-fg-muted">{row.vendor}</td>
          <td class="px-5 py-4 font-mono text-hal0-fg">{row.vram}</td>
          <td class="px-5 py-4">
            <span
              class:list={[
                'inline-block rounded-full px-2.5 py-0.5 font-mono text-[11px] uppercase tracking-wider',
                pillClass[row.status],
              ]}
            >
              {row.status}
            </span>
          </td>
          <td class="px-5 py-4 text-hal0-fg-muted">{row.notes ?? '—'}</td>
        </tr>
      ))}
    </tbody>
  </table>
</div>
