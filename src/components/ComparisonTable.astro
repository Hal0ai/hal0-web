---
/**
 * ComparisonTable — feature matrix comparing hal0 against an alternative
 * (Ollama, llama.cpp bare, vLLM, etc.). Default checkmark / dash / "•"
 * cells; pass custom strings per row.
 *
 * Props:
 *   columns – Array<{ key, label, highlight? }>
 *               first column key is the row label.
 *   rows    – Array<{ feature, [columnKey]: string | boolean }>
 *
 * Booleans render as ✓ (accent) or ✗ (dim). Strings render as-is.
 */
interface Column { key: string; label: string; highlight?: boolean }
interface Row {
  feature: string;
  [k: string]: string | boolean;
}
interface Props {
  columns: Column[];
  rows: Row[];
  caption?: string;
}
const { columns, rows, caption } = Astro.props;
---

<div class="overflow-x-auto rounded-lg border border-hal0-border bg-hal0-bg-elevated">
  {caption && (
    <p class="border-b border-hal0-border px-5 py-3 font-mono text-xs uppercase tracking-wider text-hal0-fg-muted">
      {caption}
    </p>
  )}
  <table class="tabular w-full text-left text-sm">
    <thead class="bg-hal0-bg-sunken text-xs uppercase tracking-wider text-hal0-fg-muted">
      <tr>
        <th class="px-5 py-3 font-medium">Feature</th>
        {columns.map((c) => (
          <th
            class:list={[
              'px-5 py-3 font-medium',
              c.highlight && 'text-hal0-accent',
            ]}
          >
            {c.label}
          </th>
        ))}
      </tr>
    </thead>
    <tbody>
      {rows.map((row) => (
        <tr class="border-t border-hal0-border">
          <td class="px-5 py-4 font-mono font-medium text-hal0-fg">
            {row.feature}
          </td>
          {columns.map((c) => {
            const v = row[c.key];
            if (typeof v === 'boolean') {
              return (
                <td class="px-5 py-4">
                  <span class={v ? 'text-hal0-accent' : 'text-hal0-fg-dim'}>
                    {v ? '✓' : '—'}
                  </span>
                </td>
              );
            }
            return <td class="px-5 py-4 text-hal0-fg-muted">{v ?? '—'}</td>;
          })}
        </tr>
      ))}
    </tbody>
  </table>
</div>
