---
/**
 * CTA — bottom-of-page call-to-action band.
 *
 * Props:
 *   title        – headline
 *   subtitle?    – supporting line
 *   ctaPrimary   – { href, label }
 *   ctaSecondary?– { href, label }
 *   eyebrow?     – tag above the title
 */
interface Cta { href: string; label: string }
interface Props {
  title: string;
  subtitle?: string;
  ctaPrimary: Cta;
  ctaSecondary?: Cta;
  eyebrow?: string;
}
const { title, subtitle, ctaPrimary, ctaSecondary, eyebrow } = Astro.props;
---

<section class="relative overflow-hidden border-t border-hal0-border bg-hal0-bg-sunken">
  <div class="mx-auto max-w-4xl px-6 py-20 text-center">
    {eyebrow && (
      <p class="mb-3 font-mono text-xs uppercase tracking-wider text-hal0-accent">
        {eyebrow}
      </p>
    )}
    <h2 class="text-balance text-3xl font-semibold tracking-tight text-hal0-fg md:text-4xl">
      {title}
    </h2>
    {subtitle && (
      <p class="mx-auto mt-4 max-w-2xl text-pretty text-hal0-fg-muted">
        {subtitle}
      </p>
    )}
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <a
        href={ctaPrimary.href}
        class="inline-flex items-center gap-2 rounded-md bg-hal0-accent px-5 py-3 font-mono text-sm font-medium text-black transition hover:bg-hal0-accent-hover"
      >
        {ctaPrimary.label}
      </a>
      {ctaSecondary && (
        <a
          href={ctaSecondary.href}
          class="inline-flex items-center gap-2 rounded-md border border-hal0-border px-5 py-3 font-mono text-sm font-medium text-hal0-fg transition hover:border-hal0-border-strong hover:bg-hal0-bg-elevated"
        >
          {ctaSecondary.label}
        </a>
      )}
    </div>
  </div>
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-hal0-accent/60 to-transparent"
  ></div>
</section>
