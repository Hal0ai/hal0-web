---
/**
 * Callout — a banner used to flag warnings, notes, or caveats on the
 * /install page. Keeps the surrounding markup terse and consistent.
 *
 * Props:
 *   tone   – "warning" | "note" | "danger". Default "note".
 *   title? – optional bold lead-in
 */
type Tone = 'warning' | 'note' | 'danger';
interface Props {
  tone?: Tone;
  title?: string;
}
const { tone = 'note', title } = Astro.props;

const toneClass: Record<Tone, string> = {
  warning: 'border-hal0-accent/60 bg-[var(--hal0-accent-glow)] text-hal0-fg',
  note: 'border-hal0-border bg-hal0-bg-elevated text-hal0-fg-muted',
  danger: 'border-red-500/50 bg-red-500/10 text-hal0-fg',
};

const label: Record<Tone, string> = {
  warning: 'warning',
  note: 'note',
  danger: 'danger',
};
---

<aside
  class:list={[
    'flex flex-col gap-2 rounded-lg border-l-4 border px-5 py-4 text-sm leading-relaxed',
    toneClass[tone],
  ]}
  role={tone === 'note' ? undefined : 'alert'}
>
  <p class="font-mono text-[11px] uppercase tracking-wider text-hal0-accent">
    {label[tone]}
  </p>
  {title && <p class="font-semibold text-hal0-fg">{title}</p>}
  <div class="text-hal0-fg-muted">
    <slot />
  </div>
</aside>
