---
/**
 * Expandable — native <details> wrapper with hal0 styling. Used for the
 * "What this does" section on /install so the page stays scannable
 * while keeping the full installer recipe one click away.
 *
 * Props:
 *   summary – clickable heading text
 *   open?   – open by default
 */
interface Props {
  summary: string;
  open?: boolean;
}
const { summary, open } = Astro.props;
---

<details
  open={open}
  class="group rounded-lg border border-hal0-border bg-hal0-bg-elevated open:bg-hal0-bg-elevated"
>
  <summary
    class="cursor-pointer list-none px-5 py-4 font-mono text-sm font-semibold text-hal0-fg transition hover:text-hal0-accent focus-visible:text-hal0-accent"
  >
    <span class="inline-flex items-center gap-3">
      <span
        aria-hidden="true"
        class="inline-block size-4 text-hal0-accent transition group-open:rotate-90"
      >&rsaquo;</span>
      {summary}
    </span>
  </summary>
  <div class="space-y-3 border-t border-hal0-border px-5 py-4 text-sm leading-relaxed text-hal0-fg-muted">
    <slot />
  </div>
</details>
