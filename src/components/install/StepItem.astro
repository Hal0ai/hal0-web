---
/**
 * StepItem — single step inside an install <StepList>. The numbering is
 * driven by an explicit `n` prop so screen readers and visible numbers
 * stay aligned regardless of CSS counters.
 *
 * Props:
 *   n     – step number (1-indexed)
 *   title – step heading
 *
 * Slot: body — can contain prose, CodeBlock, etc.
 */
interface Props {
  n: number;
  title: string;
}
const { n, title } = Astro.props;
---

<li class="flex gap-4 rounded-lg border border-hal0-border bg-hal0-bg-elevated p-5">
  <span
    aria-hidden="true"
    class="flex size-8 shrink-0 items-center justify-center rounded-full border border-hal0-border bg-hal0-bg font-mono text-sm font-semibold text-hal0-accent"
  >
    {n}
  </span>
  <div class="flex-1 space-y-3">
    <h3 class="font-mono text-base font-semibold tracking-tight text-hal0-fg">
      <span class="sr-only">Step {n}: </span>{title}
    </h3>
    <div class="space-y-3 text-sm leading-relaxed text-hal0-fg-muted">
      <slot />
    </div>
  </div>
</li>
