# Cloudflare Pages headers config.
# https://developers.cloudflare.com/pages/configuration/headers/
#
# Release-manifest endpoints: short cache (60s) so a freshly-published
# tag is picked up quickly by `hal0 update --check`, plus permissive
# CORS so the dashboard can fetch from a different origin during dev.

/releases/*
  Cache-Control: public, max-age=60, must-revalidate
  Access-Control-Allow-Origin: *
  Content-Type: application/json; charset=utf-8
  X-Content-Type-Options: nosniff

# One-line install bootstrap. Served as text/x-shellscript so browsers
# don't render it inline. Mirror of installer/bootstrap.sh in the hal0
# product repo — keep in sync.
/install.sh
  Content-Type: text/x-shellscript; charset=utf-8
  Cache-Control: public, max-age=300, must-revalidate
  X-Content-Type-Options: nosniff
